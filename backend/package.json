{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "mkdir -p dist && cp -r src/* dist/ && find dist -name '*.ts' -delete",
    "deploy": "cd dist && zip -r ../lambda-deployment.zip .",
    "deploy-with-deps": "cd dist && npm install --production && zip -r ../lambda-deployment.zip .",
    "dev": "nodemon src/server.js",
    "db:reset": "node scripts/reset-db.js",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.828.0",
    "@aws-sdk/client-dynamodb": "^3.828.0",
    "@aws-sdk/lib-dynamodb": "^3.828.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "nodemon": "^3.1.9",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "fast-check": "^3.23.2",
    "jest": "^29.6.4",
    "supertest": "^7.0.0"
  }
}
